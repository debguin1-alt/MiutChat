rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════════
// Miut Chat — Firestore Security Rules  v1.1.0
// ═══════════════════════════════════════════════════════════════════════════════
//
// STRUCTURE
//   rooms/{roomCode}
//     messages/{msgId}
//     members/{uid}
//     typing/{uid}
//
// PRINCIPLES
//  1. Every write requires the user to be Firebase Anonymous Auth signed-in.
//  2. Members can only read/write rooms they have an approved member doc in.
//  3. Only admins can update room-level settings (approvalRequired, epoch).
//  4. Message content is always encrypted client-side — rules only guard access.
//  5. Rate-limiting is enforced at the rule level where possible.
// ═══════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    // Is the caller Firebase-authenticated?
    function isAuthed() {
      return request.auth != null && request.auth.uid != null;
    }

    // Is the caller an approved member of this room?
    function isMember(roomCode) {
      let memberDoc = get(/databases/$(database)/documents/rooms/$(roomCode)/members/$(request.auth.uid));
      return memberDoc.data.approved == true;
    }

    // Is the caller an admin of this room?
    function isAdmin(roomCode) {
      let memberDoc = get(/databases/$(database)/documents/rooms/$(roomCode)/members/$(request.auth.uid));
      return memberDoc.data.approved == true && memberDoc.data.role == 'admin';
    }

    // Is this the caller's own UID?
    function isOwn(uid) {
      return request.auth.uid == uid;
    }

    // Validate room code format (must match client regex: letters/numbers/safe symbols, 6-64 chars)
    function validRoomCode(code) {
      return code.matches('^[a-zA-Z0-9 _\\-@#!?+*=.]{6,64}$')
          && code != '.'
          && code != '..';
    }

    // ── Room document (/rooms/{roomCode}) ────────────────────────────────────
    match /rooms/{roomCode} {

      // Anyone authed can read a room doc (to check if room exists on join)
      allow read: if isAuthed() && validRoomCode(roomCode);

      // CREATE: only authed user; minimal required fields
      allow create: if isAuthed()
                    && validRoomCode(roomCode)
                    && request.resource.data.keys().hasAll(['createdAt', 'creatorId', 'epoch'])
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.epoch == 0;

      // UPDATE: only admin members may change room settings
      allow update: if isAuthed()
                    && isAdmin(roomCode)
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['approvalRequired', 'epoch', 'emptyAt', 'salt', 'msgTtlMs']);

      // DELETE: only admin, or the transaction that sets emptyAt (room auto-wipe)
      allow delete: if isAuthed() && isAdmin(roomCode);

      // ── Messages (/rooms/{roomCode}/messages/{msgId}) ──────────────────────
      match /messages/{msgId} {

        // Only approved members can read messages
        allow read: if isAuthed() && isMember(roomCode);

        // CREATE: approved member, required fields, no future timestamps allowed
        allow create: if isAuthed()
                      && isMember(roomCode)
                      && request.resource.data.keys().hasAll(['type', 'createdAt', 'senderId'])
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.type in ['text', 'image', 'video', 'file', 'chunk', 'system'];

        // UPDATE: own messages (edit within 2 min) OR any member updating readBy/reactions
        allow update: if isAuthed()
                      && isMember(roomCode)
                      && (
                           // Any approved member can mark a message as read (readBy)
                           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
                           ||
                           // Any approved member can react
                           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
                           ||
                           // Own message edit within 2-minute window
                           (resource.data.senderId == request.auth.uid
                            && request.resource.data.diff(resource.data).affectedKeys()
                               .hasOnly(['enc', 'edited', 'editedAt', 'sig', 'ts'])
                            && resource.data.createdAt + duration.value(120, 's') > request.time)
                         );

        // DELETE: own messages only, or admin
        allow delete: if isAuthed()
                      && (resource.data.senderId == request.auth.uid || isAdmin(roomCode));
      }

      // ── Members (/rooms/{roomCode}/members/{uid}) ─────────────────────────
      match /members/{uid} {

        // Approved members can read all member docs (for presence + public keys)
        allow read: if isAuthed() && (isMember(roomCode) || isOwn(uid));

        // CREATE: user can only create their own member doc
        // Must start as role='member', approved=false (admin escalates via update)
        allow create: if isAuthed()
                      && isOwn(uid)
                      && request.resource.data.role == 'member'
                      && request.resource.data.approved == false
                      && request.resource.data.keys().hasAll(['name', 'role', 'approved', 'online', 'joinedAt']);

        // UPDATE: own doc (online/name/pubKey) OR admin escalating role/approved
        //         OR room creator self-escalating to admin on first join
        allow update: if isAuthed() && (
          // Own doc — can update presence fields and own info
          (isOwn(uid) && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['online', 'name', 'color', 'pubKey', 'joinedAt']))
          ||
          // Admin can approve/decline/promote
          (isAdmin(roomCode) && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['approved', 'role', 'online', 'declined']))
          ||
          // Room creator can self-escalate to admin immediately after their own .set()
          // Allowed only while still unapproved (prevents re-escalation) and only
          // for the exact user stored as creatorId on the room document.
          (isOwn(uid)
           && resource.data.approved == false
           && get(/databases/$(database)/documents/rooms/$(roomCode)).data.creatorId == request.auth.uid
           && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['approved', 'role']))
        );

        // DELETE: own doc or admin
        allow delete: if isAuthed() && (isOwn(uid) || isAdmin(roomCode));
      }

      // ── Typing indicators (/rooms/{roomCode}/typing/{uid}) ────────────────
      match /typing/{uid} {

        // Approved members see typing indicators
        allow read: if isAuthed() && isMember(roomCode);

        // Only write/delete your own typing doc
        allow write: if isAuthed() && isOwn(uid) && isMember(roomCode);
      }
    }

    // Block all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
