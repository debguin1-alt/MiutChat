{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "None",
    "checkJs": true,
    "allowJs": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "noEmit": true,
    "typeRoots": ["./src"]
  },
  "include": ["app.js", "db-manager.js", "sw-bridge.js", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
