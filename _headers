/*
  # ── Transport security ─────────────────────────────────────────────────────
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # ── Clickjacking / framing ──────────────────────────────────────────────────
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer

  # ── Cross-origin isolation — enables SharedArrayBuffer, precise timers ──────
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Cross-Origin-Resource-Policy: same-origin

  # ── Permissions — deny powerful browser features (only valid/current features) ─
  Permissions-Policy: camera=(), clipboard-read=(), display-capture=(), geolocation=(), microphone=(), midi=(), payment=(), usb=(), xr-spatial-tracking=()

  # ── Content Security Policy ───────────────────────────────────────────────────
  # is required to allow onclick/oninput inline event handlers
  # apis.google.com is needed for Firebase Auth iframe (separate from *.googleapis.com)
  # fonts.gstatic.com in connect-src covers font preload/fetch requests
  Content-Security-Policy: default-src 'none'; script-src 'self' https://www.gstatic.com https://www.googleapis.com https://apis.google.com; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://www.gstatic.com https://fonts.gstatic.com https://apis.google.com https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com; img-src 'self' blob: data: https://*.googleapis.com; media-src 'self' blob:; worker-src 'self'; manifest-src 'self'; frame-src https://apis.google.com https://*.firebaseapp.com; form-action 'none'; frame-ancestors 'none'; base-uri 'self'

  # ── Cache: HTML never cached, assets cached 1 year ───────────────────────────
  Cache-Control: no-store, no-cache, must-revalidate

/app.min.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

/db-manager.min.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

/sw-bridge.min.js
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

/style.min.css
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Cache-Control: public, max-age=86400

/sw.min.js
  Cache-Control: no-store
  Service-Worker-Allowed: /

/placeholder-rotator.min.js
  Cache-Control: public, max-age=31536000, immutable

/config.js
  Cache-Control: private, no-store
  X-Robots-Tag: noindex
